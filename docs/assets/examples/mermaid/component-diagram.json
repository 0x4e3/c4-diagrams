        },
        {
          "type": "RelStyle",
          "from_element": "accounts",
          "to_element": "mbsfacade",
          "offset_x": 140,
          "offset_y": 10
        },
        {
          "type": "RelStyle",
          "from_element": "security",
          "to_element": "db",
